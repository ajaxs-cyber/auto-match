# 复制此文件为 .env 并填入你的 API Key

# OpenAI API Key（用于 AI 网站分析 + 音乐推荐）
# 从 https://platform.openai.com/api-keys 获取
OPENAI_API_KEY=sk-your-key-here

# 可选：指定模型（默认 gpt-4o）
OPENAI_MODEL=gpt-4o

# 服务器端口
PORT=3001

# 音乐生成服务（可选）
# 注册获取：https://mubert.com/
MUBERT_API_KEY=

# 音乐生成服务（可选）
# 注册获取：https://soundraw.io/
SOUNDRAW_API_KEY=
